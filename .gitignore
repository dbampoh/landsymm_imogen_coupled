# =============================================================================
# Build artefacts
# =============================================================================

# CMake / make
build/
build_*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
!lpjguess/**/Makefile
!imogen/**/Makefile
!tools/**/Makefile

# Compiled object / library files
*.o
*.obj
*.so
*.so.*
*.dylib
*.dll
*.a
*.lib
*.mod
*.smod

# Compiled binaries
guess
guesscmd
runtests
imogen_lpjg
imogen_lpjg.exe
ipcc
*.exe

# Compiler dependency files (CMake auto-generated)
*.d

# Visual Studio / MSBuild artefacts
x64/
.vs/
*.vcxproj.user
*.exe.recipe
*.iobj
*.ipdb

# IDE configuration
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Python
# =============================================================================

__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
.pytest_cache/
.tox/
.coverage
htmlcov/
*.cover
.hypothesis/

# Virtual environments
.venv/
venv/
env/
ENV/

# pip
pip-log.txt
pip-delete-this-directory.txt

# =============================================================================
# Run output (regeneratable; not version-controlled)
# =============================================================================

# Per-scenario run outputs
runs/*/output/
runs/*/scratch/
runs/*/saved_state*/
runs/*/inputs/

# IMOGEN run output (per-year directories with climate files)
**/Common-directory/IMOGEN/output/
**/IMOGEN/output/

# Python Intermediary run outputs (generated by run_all.py)
intermediary_py/outputs/
intermediary_py/inputs/   # input data is large; staged via DATA.md

# Logs
*.log
guess.log
qsat_output.txt
logs/

# Per-rank cluster scratch
run[0-9]*/
tmpSPLITGRID_*

# =============================================================================
# Large input data (acquired separately; document via data/DATA.md)
# =============================================================================

# LPJ-GUESS gridded inputs (gigabytes)
data/lu/
data/ndep/*.bin
data/concentrations/IIASA/CMIP*/XLSX/
data/concentrations/IIASA/CMIP*/ZIP/

# IMOGEN auxiliary
imogen/CRUNCEP_*/
imogen/patterns/CMIP6_*/   # NetCDF patterns; staged via DATA.md
imogen/patterns/CEN_*/     # CMIP5 ASCII patterns; staged via DATA.md (preserve readme.log)
!imogen/patterns/readme.log
!imogen/patterns/README.md

# Intermediate emission files
**/co2_emissions_*.txt
**/ch4_n2o_annual_*.txt
**/total_methane_nitrogen_*.txt

# =============================================================================
# Editor / OS noise
# =============================================================================

.DS_Store
Thumbs.db
*.bak
*.tmp
~$*.docx
~WRL*.tmp

# =============================================================================
# Allow-list overrides — files we WANT to keep despite patterns above
# =============================================================================

# Keep per-subdir READMEs even when the subdir is largely gitignored
!**/README.md
