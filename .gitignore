# =============================================================================
# Run output (regeneratable; not version-controlled)
# =============================================================================

# [Step 13 of unified-codebase rebuild: adapter outputs at runs/<SSP>/inputs/
#  are derived from intermediary_py CSV outputs via tools/imogen_inputs_to_lpjg_format.py.
#  Regenerable; not committed. The output tree is at runs/<SSP>/output/. - DKB 2026-05-07]

# Per-scenario run outputs
runs/*/output/
runs/*/scratch/
runs/*/saved_state*/
runs/*/inputs/
# [Step 14: runtime artifacts produced by scripts/run_coupled.sh in each
#  scenario's Common-directory/. Engine per-year output, LPJG handshake
#  files, etc. All regenerable. - DKB 2026-05-07]
runs/*/Common-directory/

# [Step 16: workstation parallel mimic test (scripts/run_parallel_mimic.sh)
#  produces per-rank work dirs at runs/<SSP>/parallel_work/. All regenerable
#  by re-running the mimic test. - DKB 2026-05-08]
runs/*/parallel_work/

# [Step 17c.0.7: workstation mpirun -np 4 mimic xval harness
#  (scripts/cross_validate_mpi_4rank.sh) produces per-mode <mode>_<size>_runs/
#  subdirs at runs/<SSP>/parallel_work_xval_mpi/. All regenerable by re-running
#  the harness. Distinct from runs/<SSP>/parallel_work/ (Step 16) so the two
#  artifact families don't collide. - DKB 2026-05-15]
runs/*/parallel_work_xval_mpi/

# [Step 16: cluster MPI build at lpjguess/build_mpi/ produced by
#  scripts/cluster/make_guess.sh --mpi. Regenerable from source. - DKB 2026-05-08]
lpjguess/build_mpi/

# IMOGEN run output (per-year directories with climate files)
**/Common-directory/IMOGEN/output/
**/IMOGEN/output/

# Python Intermediary run outputs (generated by run_all.py)
intermediary_py/outputs/
intermediary_py/inputs/   # input data is large; staged via DATA.md
# [Step 11 of unified-codebase rebuild: the actual canonical Python pipeline
#  lives one level deeper at intermediary_py/imogen_ghg_controller/. Its
#  inputs/ + outputs/ are populated locally (Tier-3 data) but NOT committed.
#  README.md inside each is committed (acquisition instructions). - DKB 2026-05-07]
intermediary_py/imogen_ghg_controller/inputs/*
!intermediary_py/imogen_ghg_controller/inputs/README.md
intermediary_py/imogen_ghg_controller/outputs/*
!intermediary_py/imogen_ghg_controller/outputs/README.md
intermediary_py/imogen_ghg_controller/archive/*
!intermediary_py/imogen_ghg_controller/archive/README.md

# Logs
*.log
guess.log
qsat_output.txt
logs/

# Per-rank cluster scratch
run[0-9]*/
tmpSPLITGRID_*

# =============================================================================
# Large input data (acquired separately; document via data/DATA.md)
# =============================================================================

# LPJ-GUESS gridded inputs (gigabytes)
data/lu/
# Lamarque N-deposition binaries (~501 MB; staged at step 6 via tarball + fetch
# script). README.md preserved for git.
data/ndep/ndep_cruncep/
!data/ndep/README.md
data/concentrations/IIASA/CMIP*/XLSX/
data/concentrations/IIASA/CMIP*/ZIP/

# IMOGEN auxiliary (large reference data; acquired via tools/fetch_imogen_data.sh
# at step 4 of unified-codebase rebuild; never committed to git).
# NOTE 1: gitignore does NOT support inline comments after a pattern; keep
# all comments on their own lines.
# NOTE 2: a file under an EXCLUDED parent directory cannot be re-included via "!".
# So when we want to keep a README.md within an otherwise-excluded subdir,
# we must exclude the dir's *contents* (using "<dir>/*") rather than the dir
# itself, then re-include the README.
#
# 30-year base climatology (CRUNCEP 1960-1989, ~60 MB; preserve README.md)
imogen/CRUNCEP_1960_1989/*
# 5 CMIP6 NetCDF patterns (~20 MB)
imogen/patterns/CMIP6_*/
# 34 CMIP5 ASCII patterns (~82 MB)
imogen/patterns/CEN_*/
# 1 CMIP3 legacy pattern (~2 MB)
imogen/patterns/ukmo_hadcm3_rel/
# Fortran namelists derived from CMIP6 *_params.json (regenerated by
# tools/cmip6_nc_to_cmip5_ascii.py at step 5; not committed).
imogen/patterns/*_ebm.nml
# Reference emission files (~20 KB historical RCP8.5; staged in step 4 for the
# standalone smoke test; will be moved into a tarball at step 6; preserve README.md)
imogen/emiss/*
# Run-time state for standalone IMOGEN smoke runs from imogen/code/
# (binary writes CO2_all.dat, RF_all.dat, VARYEAR.dat, output/<YYYY>/ here, plus
# stub LPJG_main files needed to satisfy the polling loop until step 7's source fix).
imogen/code/IMOGEN/
imogen/code/runtime/
imogen/code/LPJG_main/
# Fortran scratch files (gfortran writes fort.<unit> when an OPEN uses a numeric
# unit without an explicit FILE=)
fort.[0-9]*
# Allow-list overrides — small upstream/internal docs we DO want to track
!imogen/patterns/readme.log
!imogen/patterns/README.md
!imogen/CRUNCEP_1960_1989/README.md
!imogen/emiss/README.md

# Intermediate emission files
**/co2_emissions_*.txt
**/ch4_n2o_annual_*.txt
**/total_methane_nitrogen_*.txt

